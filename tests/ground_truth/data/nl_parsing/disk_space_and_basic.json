[
  {
    "test_id": "NL-001",
    "category": "nl_parsing",
    "description": "Simple disk space query - less than",
    "input": {
      "text": "Find all devices with less than 10GB free disk space"
    },
    "expected_output": {
      "entity_type": "devices",
      "conditions": [
        {
          "field": "disk_free_space_gb",
          "operator": "less_than",
          "value": 10,
          "unit": "GB"
        }
      ],
      "logical_operator": null
    },
    "acceptable_variations": [
      {
        "conditions": [
          {
            "field": "free_disk_space",
            "operator": "<",
            "value": 10
          }
        ]
      }
    ],
    "evaluation_mode": "semantic",
    "metadata": {
      "author": "system",
      "created_date": "2026-01-31",
      "difficulty": "easy",
      "tags": ["disk_space", "simple_query", "less_than"]
    }
  },
